# Environment Configuration — HR OS
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-secret-key
APP_DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hros
POSTGRES_USER=hros
POSTGRES_PASSWORD=hros_dev_password
DATABASE_URL=postgresql+asyncpg://hros:hros_dev_password@localhost:5432/hros

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET=hros
MINIO_USE_SSL=false
STORAGE_URL_EXPIRY_SECONDS=900

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Temporal ─────────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=hros-dev

# ─── AI Model Gateway ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-1.5-flash

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=hros-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@hros.local
